.vscode/**
.vscode-test/**
src/**
img/**
.gitignore
.eslintrc.cjs
**/tsconfig.json
**/*.map
**/*.ts
package-lock.json
.github-release-notes.md
out/test/**
.codex
.claude
.serena
*.zip

# CI / docs / scripts (not needed at runtime)
.github/workflows/**
docs/**
scripts/**

# Exclude all katex/mermaid files, then re-include only what's needed
node_modules/katex/**
!node_modules/katex/dist/katex.min.js
!node_modules/katex/dist/katex.min.css
!node_modules/katex/dist/fonts/**
node_modules/mermaid/**
!node_modules/mermaid/dist/mermaid.min.js
node_modules/@mermaid-js/**
# Exclude debug/demo/unnecessary files from other dependencies
node_modules/sql.js/dist/*-debug.*
node_modules/sql.js/dist/*-memory-growth.*
node_modules/sql.js/dist/sql-asm.js
node_modules/sql.js/dist/worker.sql-asm.js
node_modules/sql.js/dist/sql-wasm-browser-debug.wasm
node_modules/sql.js/dist/sql-wasm-browser.wasm
node_modules/cytoscape-fcose/demo/**
node_modules/cytoscape/dist/cytoscape.umd.js
node_modules/cytoscape/dist/cytoscape.cjs.js
node_modules/cytoscape/dist/cytoscape.esm.mjs

# Prune unnecessary files from all node_modules
**/*.d.mts
**/*.d.ts
**/*.d.cts
**/*.spec.js
**/*.test.js
**/node_modules/**/test/**
**/node_modules/**/tests/**
**/node_modules/**/tests-examples/**
**/node_modules/**/.github/**
**/node_modules/**/CHANGELOG*
**/node_modules/**/README*
**/node_modules/**/LICENSE*
**/node_modules/**/CODE_OF_CONDUCT*
**/node_modules/**/CONTRIBUTING*
**/node_modules/**/.eslint*
**/node_modules/**/.prettier*
